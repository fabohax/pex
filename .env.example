# Stacks Network Configuration
STACKS_NETWORK=testnet
STACKS_API_URL=https://stacks-testnet-api.blockstack.org
STACKS_RPC_URL=http://localhost:20443

# Wallet Configuration
DEPLOYER_MNEMONIC=your-mnemonic-here
DEPLOYER_ADDRESS=your-address-here

# Oracle Configuration
PRIMARY_ORACLE_ADDRESS=oracle1.stacks
SECONDARY_ORACLE_ADDRESS=oracle2.stacks
TERTIARY_ORACLE_ADDRESS=oracle3.stacks

# PEX Contract Configuration
PEX_TOKEN_NAME=PEX Synthetic Sol
PEX_TOKEN_SYMBOL=PEX
INITIAL_ORACLE_CONSENSUS_THRESHOLD=2

# Collateral Configuration
COLLATERAL_TYPE=STX
MIN_BURN_AMOUNT=1000000
MAX_MINT_PER_TX=100000000000

# Price Feed Configuration
PRICE_UPDATE_INTERVAL=300
PRICE_DEVIATION_THRESHOLD=100
